{
  "name": "@vltpkg/policies",
  "version": "2.0.2",
  "description": "GitHub Action to gate CI with vlt dependency policies",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --target=node20 --format=cjs --minify",
    "build:dev": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --target=node20 --format=cjs --sourcemap",
    "test": "node --import tsx --test tests/*.test.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write .",
    "prepack": "vlt run build",
    "release": "./scripts/release.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vltpkg/policies.git"
  },
  "keywords": [
    "vlt",
    "github-action",
    "security",
    "dependencies",
    "malware",
    "outdated"
  ],
  "author": {
    "name": "vltpkg"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "esbuild": "^0.20.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  }
}
